rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Fotos de los centros de acopio: lectura pública, subida limitada a imágenes < 5MB.
    match /centros/{centroId}/{archivo} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
