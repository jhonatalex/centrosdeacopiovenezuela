# Copia este archivo como .env.local y rellena con los datos de tu proyecto Firebase.
# Consola Firebase → Configuración del proyecto → Tus apps → SDK de configuración.
# Si dejas estas variables vacías, la app corre en MODO DEMO (datos locales en el navegador).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Correos (separados por coma) con permisos de administrador para aprobar/rechazar centros.
NEXT_PUBLIC_ADMIN_EMAILS=tucorreo@gmail.com
